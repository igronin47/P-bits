from p_kit.core import PCircuit
from p_kit.solver.csd_solver import CaSuDaSolver
from p_kit.visualization import histplot
import numpy as np


# ================= P-CIRCUIT DEFINITION =================
c = PCircuit(5)

# Variable mapping:
# [x1, x2, x3, y0, y1]

c.J = np.array([
    [ 0, -1, -1,  1,  2],  # x1
    [-1,  0, -1,  1,  2],  # x2
    [-1, -1,  0,  1,  2],  # x3
    [ 1,  1,  1,  0, -2],  # y0
    [ 2,  2,  2, -2,  0]   # y1
])

# h vector (all zeros)
c.h = np.zeros(5)

# 8 input bitcunt
# c.J = np.array([
    [ 0, -1, -1, -1, -1, -1, -1,  1,  2,  4],  # x1
    [-1,  0, -1, -1, -1, -1, -1,  1,  2,  4],  # x2
    [-1, -1,  0, -1, -1, -1, -1,  1,  2,  4],  # x3
    [-1, -1, -1,  0, -1, -1, -1,  1,  2,  4],  # x4
    [-1, -1, -1, -1,  0, -1, -1,  1,  2,  4],  # x5
    [-1, -1, -1, -1, -1,  0, -1,  1,  2,  4],  # x6
    [-1, -1, -1, -1, -1, -1,  0,  1,  2,  4],  # x7
    [ 1,  1,  1,  1,  1,  1,  1,  0, -2, -4],  # y0
    [ 2,  2,  2,  2,  2,  2,  2, -2,  0, -8],  # y1
    [ 4,  4,  4,  4,  4,  4,  4, -4, -8,  0]   # y2
])

# h vector (all zeros)
# c.h = np.zeros(10)



# ================= SOLVER CONFIGURATION =================
solver = CaSuDaSolver(
    Nt=25000,   # number of iterations
    dt=0.1667,  # time step
    i0=0.5      # inverse temperature (beta)
)


# ================= RUN SIMULATION =================
input_states, output_states = solver.solve(c)


# ================= VISUALIZATION =================
histplot(output_states)
