import sympy as sp
import numpy as np
x1,x2,y =sp.symbols('x1 x2 y') #Inputs-Outputs
variables = [x1, x2, y]
# Cost function 
cost = sp.expand((y - (x1 - x2)**2)**2)  
# Initialize parameters
n = len(variables)  
J = np.zeros((n, n))
h = np.zeros(n)
# Fill J and h using negative coefficients
for term in cost.as_ordered_terms():
    coeff = -term.as_coeff_Mul()[0]
    symbols = list(term.as_coeff_Mul()[1].free_symbols)
    if len(symbols) == 1:  # h matrix
        i = variables.index(symbols[0])
        h[i] += coeff
    elif len(symbols) == 2:  # J matrix
        i, j = variables.index(symbols[0]), variables.index(symbols[1])
        if i != j:
            J[i][j] += coeff
            J[j][i] += coeff  # symmetry


